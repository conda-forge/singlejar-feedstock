From baba2b9b4ebbccb7d890c2befea8daa10f329a3b Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwelk@xhochy.com>
Date: Sun, 21 Mar 2021 21:26:54 +0100
Subject: [PATCH 2/2] Build with native dependencies

---
 MODULE.bazel                                  | 18 ++++-----------
 .../java/com/google/devtools/build/lib/BUILD  |  2 +-
 third_party/grpc/BUILD                        | 23 ++++++++-----------
 third_party/systemlibs/protobuf_deps.bzl      |  2 ++
 4 files changed, 17 insertions(+), 28 deletions(-)
 create mode 100644 third_party/systemlibs/protobuf_deps.bzl

diff --git a/MODULE.bazel b/MODULE.bazel
index 62c1c29..fbec7cc 100755
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -13,7 +13,7 @@ module(
 # Bazel module dependencies
 # =========================================
 
-bazel_dep(name = "abseil-cpp", version = "20250814.1")
+bazel_dep(name = "abseil-cpp", version = "ABSEIL_VERSION")
 bazel_dep(name = "bazel_skylib", version = "1.8.2")
 bazel_dep(name = "blake3", version = "1.8.2")
 bazel_dep(name = "googleapis-grpc-java", version = "1.0.0")
@@ -38,6 +38,10 @@ bazel_dep(name = "stardoc", version = "0.8.0", repo_name = "io_bazel_skydoc")
 bazel_dep(name = "with_cfg.bzl", version = "0.13.0")
 bazel_dep(name = "zlib", version = "1.3.1.bcr.7")
 bazel_dep(name = "zstd-jni", version = "1.5.6-9")
+local_path_override(
+    module_name = "protobuf",
+    path = "./third_party/systemlibs/protobuf",
+)
 
 # Depend on apple_support first and then rules_cc so that the Xcode toolchain
 # from apple_support wins over the generic Unix toolchain from rules_cc.
@@ -100,18 +104,6 @@ single_version_override(
     version = "1.2.1.bcr.1",
 )
 
-# 1. Expose @com_google_protobuf//java/core:lite_runtime_only
-# due to https://github.com/protocolbuffers/protobuf/commit/079be27925955348d1b3cb30ffbfa33dcec5778c
-# We need to package the lite runtime jar for Bazel's bootstrap build
-# 2. Partially revert of https://github.com/protocolbuffers/protobuf/commit/7ec5e19c0743b80c5097434a05cc0e972e7b4e7a
-# to support grpc
-single_version_override(
-    module_name = "protobuf",
-    patch_strip = 1,
-    patches = ["//third_party:protobuf.patch"],
-    version = "33.4",
-)
-
 # Remove once the following PRs are available in a grpc-java release.
 #   https://github.com/grpc/grpc-java/pull/12148
 #   https://github.com/grpc/grpc-java/pull/12207
diff --git a/src/main/java/com/google/devtools/build/lib/BUILD b/src/main/java/com/google/devtools/build/lib/BUILD
index d385177..db65056 100755
--- a/src/main/java/com/google/devtools/build/lib/BUILD
+++ b/src/main/java/com/google/devtools/build/lib/BUILD
@@ -582,7 +582,7 @@ java_library(
         "//third_party:guava",
         "//third_party:jsr305",
         "@com_google_protobuf//:protobuf_java",
-        "@com_google_protobuf//java/util",
+        "@com_google_protobuf//:protobuf_java_util",
         "@zstd-jni//:zstd-jni",
     ],
 )
diff --git a/third_party/grpc/BUILD b/third_party/grpc/BUILD
index 1ef653c..f5e9185 100755
--- a/third_party/grpc/BUILD
+++ b/third_party/grpc/BUILD
@@ -39,28 +39,23 @@ filegroup(
     ],
 )
 
-alias(
+genrule(
     name = "cpp_plugin",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_bin_deps//:grpc-cpp-plugin",
-        "//conditions:default": "@com_github_grpc_grpc//src/compiler:grpc_cpp_plugin",
-    }),
+    outs = ["grpc-cpp-plugin.out"],
+    cmd = "ln -s $(BUILD_PREFIX)/bin/grpc_cpp_plugin $@",
+    executable = 1,
+    visibility = ["//visibility:public"],
 )
 
 alias(
     name = "grpc++_codegen_proto",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_cc_deps//:grpc++_unsecure",
-        "//conditions:default": "@com_github_grpc_grpc//:grpc++_codegen_proto",
-    }),
+    actual = "grpc++_unsecure",
 )
 
-alias(
+cc_library(
     name = "grpc++_unsecure",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_cc_deps//:grpc++_unsecure",
-        "//conditions:default": "@com_github_grpc_grpc//:grpc++_unsecure",
-    }),
+    linkopts = ["-lgrpc++_unsecure", "-lgrpc_unsecure","-lgpr"],
+    visibility = ["//visibility:public"],
 )
 
 filegroup(
diff --git a/third_party/systemlibs/protobuf_deps.bzl b/third_party/systemlibs/protobuf_deps.bzl
new file mode 100644
index 0000000..aafd89b
--- /dev/null
+++ b/third_party/systemlibs/protobuf_deps.bzl
@@ -0,0 +1,2 @@
+def protobuf_deps():
+    pass
